# Geno Finder — local dev env example
# 실제 값은 .env (gitignore) 에 작성.
#
# 운영 환경에서는 KMS/Vault 가 secret 을 런타임 주입한다 (ADR 0002 §12.10).
# .env 파일은 dev 전용.

# --- Postgres ---
POSTGRES_PASSWORD=devpassword

# --- OpenSearch (dev only — security plugin 비활성) ---
OPENSEARCH_PASSWORD=DevAdmin!1

# --- API ---
# ADR 0002 T4: 두 종류의 DB URL 분리
#   DATABASE_URL          앱 런타임 (NOSUPERUSER role — RLS 적용)
#   ALEMBIC_DATABASE_URL  마이그레이션 (superuser — 스키마 변경 권한)
DATABASE_URL=postgresql+asyncpg://genofinder_app:devpassword@localhost:5432/genofinder
ALEMBIC_DATABASE_URL=postgresql+asyncpg://genofinder:devpassword@localhost:5432/genofinder
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
OPENSEARCH_URL=http://localhost:9200

# --- Ollama (ADR 0003) ---
OLLAMA_URL=http://localhost:11434
# 모델 이름은 ADR 0004 (Week 3) 결정 후 채움
OLLAMA_MODEL_EXTRACTION=
OLLAMA_MODEL_EMBED=

# --- NCBI ---
# api_key 가 있으면 10rps, 없으면 3rps (docs/external-apis.md §1)
NCBI_EUTILS_API_KEY=

# --- KMS ---
KMS_PROVIDER=localstack
KMS_ENDPOINT_URL=http://localhost:4566
KMS_KEK_ALIAS=alias/genofinder-tenant-kek

# --- Tenant header (Firebase Auth 도입 전 레거시 — 점진적 폐기 예정) ---
APP_TENANT_HEADER=X-Tenant-Id

# --- Firebase Auth (ADR 0005) ---
# 백엔드는 Firebase ID 토큰을 검증해 사용자를 식별한다.
# service-account JSON 의 절대경로. compose 에서 host 의 파일을 read-only 마운트한다.
# - host: /home/hojin/bioinfo0929/work_7_search/genofinder-55e4a-firebase-adminsdk-fbsvc-*.json
# - container: /run/secrets/firebase-admin.json
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-admin.json
FIREBASE_ADMIN_CREDENTIALS_HOST_PATH=/home/hojin/bioinfo0929/work_7_search/genofinder-55e4a-firebase-adminsdk-fbsvc-656057cd81.json

# --- Reranker (cross-encoder, optional) ---
# CPU 환경: top_n=20 이 현실적. 더 빠른 응답 원하면 0 (=비활성).
# GPU 환경: 100 까지 안전.
RERANKER_TOP_N=20
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
