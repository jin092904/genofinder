# A100 서버용 .env 템플릿 — 사용자 home 의 실제 경로/키로 채워 ~/genofinder/.env 로 복사.
# ADR 0006 + migration_v2.md 참조.

# --- NFS / 저장 위치 (필수) ---
GENOFINDER_DATA_ROOT=/home/sosa8770/genofinder

# --- GPU 선택 (필수, A100 서버에서 비어있는 번호) ---
NVIDIA_GPU_DEVICE_ID=3

# --- Postgres ---
POSTGRES_PASSWORD=devpassword

# --- NCBI E-utilities API key (없어도 동작, rate 3rps → 10rps 향상) ---
NCBI_EUTILS_API_KEY=

# --- OpenSearch admin password (dev) ---
OPENSEARCH_PASSWORD=DevAdmin!1

# --- Firebase Admin SDK service account JSON 경로 (호스트 측 절대 경로) ---
# 없으면 인증 관련 엔드포인트 (/me, /me/saved) 가 401 — 그러나 검색 / 코호트 / 다운로드는 정상 동작
FIREBASE_ADMIN_CREDENTIALS_HOST_PATH=/home/sosa8770/genofinder/firebase-admin.json
