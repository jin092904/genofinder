# Geno Finder evaluation pipeline 환경변수 템플릿.
# `.env` (실제 값) 는 git ignore. 본 .example 만 commit.

# Geno Finder API endpoint (FastAPI). batch 끝난 뒤 uvicorn 가동.
GENOFINDER_API_BASE=http://localhost:8000

# Firebase ID token 또는 dev bypass token. 빈 값이면 client 가 dev bypass 시도.
GENOFINDER_BEARER_TOKEN=

# 데이터 위치
EVAL_DATA_DIR=/home/sosa8770/genofinder/evaluation/data
EVAL_RESULTS_DIR=/home/sosa8770/genofinder/evaluation/results

# bioCADDIE corpus 는 4GB 추정 → NFS 회피, /var/tmp 에 저장 (symlink 로 evaluation/data/biocaddie/corpus.jsonl 에 연결)
EVAL_BIOCADDIE_CORPUS_DIR=/var/tmp/genofinder-eval/biocaddie

# 재현성
EVAL_SEED=42

# 로그
EVAL_LOG_LEVEL=INFO
